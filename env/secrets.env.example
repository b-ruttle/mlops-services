# --- Postgres ---
POSTGRES_USER=postgres-admin
POSTGRES_PASSWORD=change_me_strong

# --- RustFS (S3-compatible) ---
RUSTFS_ACCESS_KEY=rustfs-admin
RUSTFS_SECRET_KEY=change_me_to_a_long_random_secret

# --- MLflow basic auth bootstrap ---
MLFLOW_FLASK_SERVER_SECRET_KEY=change_me_to_a_long_random_secret
MLFLOW_AUTH_ADMIN_USERNAME=mlflow-admin
MLFLOW_AUTH_ADMIN_PASSWORD=change_me_admin_password

# --- MLflow admin app login (separate from MLflow users) ---
MLFLOW_ADMIN_APP_USERNAME=admin-app
MLFLOW_ADMIN_APP_PASSWORD=change_me_admin_app_password
MLFLOW_ADMIN_APP_SECRET_KEY=change_me_mlflow_admin_app_secret_key

# --- Airflow bootstrap ---
AIRFLOW_FERNET_KEY=change_me_to_a_32_byte_urlsafe_base64_key
AIRFLOW_SECRET_KEY=change_me_airflow_web_secret_key
AIRFLOW_ADMIN_USERNAME=airflow-admin
AIRFLOW_ADMIN_PASSWORD=change_me_airflow_admin_password
AIRFLOW_ADMIN_FIRSTNAME=Airflow
AIRFLOW_ADMIN_LASTNAME=Admin
AIRFLOW_ADMIN_EMAIL=airflow-admin@example.local
