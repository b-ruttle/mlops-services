# --- Postgres ---
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=change_me_strong

# --- RustFS (S3-compatible) ---
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=change_me_to_a_long_random_secret

# --- Keycloak admin + database ---
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_keycloak_admin
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change_me_keycloak_db

# --- OIDC gateway (oauth2-proxy + Keycloak client secret) ---
# Must match the client secret configured for OAUTH2_PROXY_CLIENT_ID in Keycloak.
KEYCLOAK_GATEWAY_CLIENT_SECRET=change_me_gateway_client_secret
OAUTH2_PROXY_CLIENT_SECRET=change_me_gateway_client_secret
OAUTH2_PROXY_COOKIE_SECRET=replace_with_32_byte_base64_cookie_secret

# --- Vault ---
# Used by the dev-mode Vault service for local bootstrap.
VAULT_DEV_ROOT_TOKEN=change_me_vault_root_token
