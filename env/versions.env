# MLflow build base: mlflow-server/mlflow/Dockerfile
PYTHON_IMAGE=python:3.11-slim

# Postgres service: mlflow-server/postgres/docker-compose.yml
POSTGRES_IMAGE=postgres:16

# RustFS services: mlflow-server/rustfs/docker-compose.yml
RUSTFS_IMAGE=rustfs/rustfs:latest # Main service (S3-compatible object store)
MC_IMAGE=minio/mc:latest # Bucket init
ALPINE_IMAGE=alpine:3.20 # Volume permission helper

# Gateway and identity stack
NGINX_IMAGE=nginx:1.27-alpine
OAUTH2_PROXY_IMAGE=quay.io/oauth2-proxy/oauth2-proxy:v7.8.2
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.0

# Secrets management
VAULT_IMAGE=hashicorp/vault:1.16
