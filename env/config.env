# Docker network
MLOPS_NETWORK=mlops

# Public endpoint + path routing
NGINX_PORT=7777
NGINX_PORT_BIND=127.0.0.1
PUBLIC_FQDN=localhost
MLFLOW_BASE_PATH=mlflow
MLFLOW_ADMIN_BASE_PATH=mlflow-admin
AIRFLOW_BASE_PATH=airflow
RUSTFS_BASE_PATH=rustfs

# MLflow 
MLFLOW_PORT=5000
MLFLOW_ADMIN_PORT=8080
MLFLOW_BIND_HOST=0.0.0.0
MLFLOW_AUTH_DEFAULT_PERMISSION=READ

# Airflow
AIRFLOW_PORT=8081
AIRFLOW_POSTGRES_DB=airflow
AIRFLOW_PROJECTS_DIR=../../..

# Postgres
POSTGRES_PORT=5432
POSTGRES_DB=mlflow
MLFLOW_AUTH_POSTGRES_DB=mlflow_auth
FEAST_POSTGRES_DB=feast
POSTGRES_DATA_DIR=../../../volumes/mlops-data/postgres

# RustFS (S3-compatible)
RUSTFS_PORT=9000
RUSTFS_CONSOLE_PORT=9001
RUSTFS_DATA_DIR=../../../volumes/mlops-data/rustfs

# Buckets
MLFLOW_ARTIFACT_BUCKET=mlflow-artifacts
DVC_BUCKET=dvc-remote

# AWS SDK defaults (boto3)
AWS_DEFAULT_REGION=us-east-1
