# Docker network
MLOPS_NETWORK=mlops

# Public endpoint + routing
PUBLIC_FQDN=mlops.example.internal
MLFLOW_BASE_PATH=/mlflow
KEYCLOAK_BASE_PATH=/auth
OAUTH2_PROXY_BASE_PATH=/oauth2

# Nginx (only public service)
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_HTTP_BIND=0.0.0.0
NGINX_HTTPS_BIND=0.0.0.0
TLS_CERTS_DIR=./nginx/certs
TLS_CERT_FILE=tls.crt
TLS_KEY_FILE=tls.key

# MLflow
MLFLOW_PORT=5000
MLFLOW_BIND_HOST=0.0.0.0

# Postgres
POSTGRES_PORT=5432
POSTGRES_DB=mlflow
POSTGRES_DATA_DIR=../../../volumes/mlops-data/postgres

# Keycloak + its Postgres database
KEYCLOAK_PORT=8080
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_POSTGRES_DATA_DIR=../../../volumes/mlops-data/keycloak-postgres

# RustFS (S3-compatible)
RUSTFS_PORT=9000
RUSTFS_CONSOLE_PORT=9001
RUSTFS_DATA_DIR=../../../volumes/mlops-data/rustfs

# oauth2-proxy
OAUTH2_PROXY_PORT=4180
OAUTH2_PROXY_CLIENT_ID=mlflow-gateway

# Vault
VAULT_PORT=8200
VAULT_PORT_BIND=127.0.0.1
VAULT_KV_MOUNT=secret
VAULT_SECRET_PREFIX=mlops-services/prod

# Buckets
MLFLOW_ARTIFACT_BUCKET=mlflow-artifacts
DVC_BUCKET=dvc-remote

# AWS SDK defaults (boto3)
AWS_DEFAULT_REGION=us-east-1
