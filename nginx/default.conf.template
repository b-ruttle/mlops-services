map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

# HTTP-only for now. Add parallel `listen 443 ssl;` server blocks when enabling TLS.
server {
    listen 80;
    server_name ${PUBLIC_FQDN} localhost 127.0.0.1;

    location = / {
        default_type text/html;
        return 200 '<!doctype html><html><head><meta charset="utf-8"><title>MLOps Services</title></head><body><h1>MLOps Services</h1><ul><li><a href="${MLFLOW_BASE_PATH}/">MLflow</a></li><li><a href="${RUSTFS_BASE_PATH}/">RustFS Console</a></li><li><a href="${RUSTFS_API_BASE_PATH}/">RustFS API</a></li></ul></body></html>';
    }

    location = ${MLFLOW_BASE_PATH} {
        return 301 ${MLFLOW_BASE_PATH}/;
    }

    location ${MLFLOW_BASE_PATH}/ {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Prefix ${MLFLOW_BASE_PATH};
        proxy_read_timeout 300;
        proxy_pass http://mlflow:${MLFLOW_PORT}/;
    }

    location = ${RUSTFS_BASE_PATH} {
        return 301 ${RUSTFS_BASE_PATH}/;
    }

    location = ${RUSTFS_BASE_PATH}/ {
        return 302 ${RUSTFS_BASE_PATH}/console/;
    }

    location ${RUSTFS_BASE_PATH}/ {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Prefix ${RUSTFS_BASE_PATH};
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_pass http://rustfs:${RUSTFS_CONSOLE_PORT};
    }

    location = ${RUSTFS_API_BASE_PATH} {
        return 301 ${RUSTFS_API_BASE_PATH}/;
    }

    location ${RUSTFS_API_BASE_PATH}/ {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Prefix ${RUSTFS_API_BASE_PATH};
        proxy_pass http://rustfs:${RUSTFS_PORT}/;
    }
}

server {
    listen 80 default_server;
    server_name _;
    return 404;
}
