map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

# HTTP-only for now. Add parallel `listen 443 ssl;` server blocks when enabling TLS.
server {
    listen 80;
    server_name ${PUBLIC_FQDN} localhost 127.0.0.1;
    error_page 418 = @rustfs_console_root_post;

    # Re-resolve Docker service names so proxying survives container restarts/recreates.
    resolver 127.0.0.11 valid=10s ipv6=off;

    location = / {
        # RustFS console APIs may hit "/" with POST or "?session" query.
        if ($query_string ~* "(^|&)session(=|&|$)") {
            return 418;
        }
        if ($request_method = POST) {
            return 418;
        }

        default_type text/html;
        return 200 '<!doctype html><html><head><meta charset="utf-8"><title>MLOps Services</title></head><body><h1>MLOps Services</h1><ul><li><a href="${MLFLOW_BASE_PATH}/">MLflow</a></li><li><a href="${RUSTFS_BASE_PATH}/">RustFS Console</a></li><li><a href="${RUSTFS_API_BASE_PATH}/">RustFS API</a></li></ul></body></html>';
    }

    location @rustfs_console_root_post {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Prefix ${RUSTFS_BASE_PATH};
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        set $rustfs_console_upstream rustfs:${RUSTFS_CONSOLE_PORT};
        proxy_pass http://$rustfs_console_upstream;
    }

    location = ${MLFLOW_BASE_PATH} {
        return 301 ${MLFLOW_BASE_PATH}/;
    }

    location ${MLFLOW_BASE_PATH}/ {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Prefix ${MLFLOW_BASE_PATH};
        proxy_read_timeout 300;
        proxy_pass http://mlflow:${MLFLOW_PORT}/;
    }

    location = ${RUSTFS_BASE_PATH} {
        return 301 ${RUSTFS_BASE_PATH}/;
    }

    location = ${RUSTFS_BASE_PATH}/ {
        return 302 ${RUSTFS_BASE_PATH}/console/;
    }

    location ${RUSTFS_BASE_PATH}/ {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Prefix ${RUSTFS_BASE_PATH};
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        set $rustfs_console_upstream rustfs:${RUSTFS_CONSOLE_PORT};
        proxy_pass http://$rustfs_console_upstream;
    }

    location = ${RUSTFS_API_BASE_PATH} {
        return 301 ${RUSTFS_API_BASE_PATH}/;
    }

    location ${RUSTFS_API_BASE_PATH}/ {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Prefix ${RUSTFS_API_BASE_PATH};
        set $rustfs_api_upstream rustfs:${RUSTFS_PORT};
        proxy_pass http://$rustfs_api_upstream/;
    }
}

server {
    listen 80 default_server;
    server_name _;
    return 404;
}
