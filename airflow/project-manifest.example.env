# Copy this file into a project repo as .airflow-project.env
# Paths are relative to the project repo root.

# Optional. Defaults to the repo directory name.
PROJECT_NAME=my-project

# Optional. Defaults to dags
DAGS_DIR=dags

# Optional extra env file sourced into Airflow before DAG parsing and execution.
# Discovery also exports <PROJECT>_REPO_HOST_DIR automatically from the
# host checkout path, for example MY_PROJECT_REPO_HOST_DIR for PROJECT_NAME=my-project.
ENV_FILE=airflow/airflow.env
